{
  "env": {
    "browser": true,
    "commonjs": true,
    "es2021": true
  },
  "root": true,

  "ignorePatterns": ["node_modules", ".cache", "public"],
  "plugins": ["prettier", "cypress", "@typescript-eslint"],
  "extends": ["standard-with-typescript", "eslint:recommended", "plugin:prettier/recommended"],
  "overrides": [
    {
      "files": ["*.ts", "*.js"],
      "extends": ["plugin:cypress/recommended", "prettier"],
      "rules": { "cypress/no-unnecessary-waiting": "off" },
      "env": {
        "cypress/globals": true
      }
    }
  ],
  "parserOptions": {
    "parser": "@typescript-eslint/parser",
    "ecmaVersion": "latest",
    "project": "./tsconfig.json"
  },
  "rules": {
    "no-console": "warn",
    "indent": ["error", 2],
    "quotes": ["error", "single"],
    "semi": ["error", "always"],
    "no-var": "error",
    "no-unused-vars": "error",
    "no-undef": "error",
    "no-magic-numbers": ["off", { "ignore": [-1, 0, 1, 2] }],
    "prefer-const": "error",
    "no-unused-expressions": "error",
    "prettier/prettier": ["warn", { "endOfLine": "auto" }],
    "arrow-parens": ["off", "as-needed"],
    "cypress/no-assigning-return-values": "warn",
    "cypress/assertion-before-screenshot": "warn",
    "cypress/no-force": "off",
    "cypress/no-async-tests": "off",
    "cypress/no-pause": "warn",
    "@typescript-eslint/restrict-plus-operands": "error",
    "@typescript-eslint/explicit-function-return-type": "off",
    "@typescript-eslint/no-var-requires": "off",
    "@typescript-eslint/strict-boolean-expressions": "off",
    "@typescript-eslint/consistent-type-imports": "warn",
    "eslint-disable spaced-comment": "off",
    "@typescript-eslint/restrict-template-expressions": "off",
    "@typescript-eslint/no-base-to-string": "off"
  }
}
